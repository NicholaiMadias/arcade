// --- API UTILS ---

// Exponential Backoff Fetch
const fetchWithRetry = async (url, options, retries = 5) => {
  for (let i = 0; i < retries; i++) {
    try {
      const res = await fetch(url, options);
      if (res.ok) return res;
    } catch (e) {
      if (i === retries - 1) throw e;
    }
    await new Promise(r => setTimeout(r, Math.pow(2, i) * 1000));
  }
};

const callGemini = async (prompt, systemPrompt) => {
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
  const payload = {
    contents: [{ parts: [{ text: prompt }] }],
    systemInstruction: { parts: [{ text: systemPrompt }] }
  };

  try {
    const res = await fetchWithRetry(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    return data.candidates?.[0]?.content?.parts?.[0]?.text;
  } catch (e) {
    return "Connection to the Lattice disrupted.";
  }
};

const generateImage = async (prompt) => {
  const url = `https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`;
  const payload = {
    instances: { prompt },
    parameters: { sampleCount: 1 }
  };

  try {
    const res = await fetchWithRetry(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    return `data:image/png;base64,${data.predictions[0].bytesBase64Encoded}`;
  } catch (e) {
    return null;
  }
};

const generateSpeech = async (text) => {
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`;
  const payload = {
    contents: [{ parts: [{ text }] }],
    generationConfig: {
      responseModalities: ["AUDIO"],
      speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Kore" } } }
    }
  };

  try {
    const res = await fetchWithRetry(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    const audioData = data.candidates?.[0]?.content?.parts?.[0]?.inlineData;
    if (!audioData) return null;

    // Convert PCM to WAV
    const pcmData = Uint8Array.from(atob(audioData.data), c => c.charCodeAt(0));
    const sampleRate = parseInt(audioData.mimeType.split('rate=')[1]) || 24000;
    return createWavBlob(pcmData, sampleRate);
  } catch (e) {
    return null;
  }
};

const createWavBlob = (pcmData, sampleRate) => {
  const buffer = new ArrayBuffer(44 + pcmData.length);
  const view = new DataView(buffer);

  const writeString = (offset, string) => {
    for (let i = 0; i < string.length; i++) {
      view.setUint8(offset + i, string.charCodeAt(i));
    }
  };

  writeString(0, 'RIFF');
  view.setUint32(4, 36 + pcmData.length, true);
  writeString(8, 'WAVE');
  writeString(12, 'fmt ');
  view.setUint32(16, 16, true);
  view.setUint16(20, 1, true);
  view.setUint16(22, 1, true);
  view.setUint32(24, sampleRate, true);
  view.setUint32(28, sampleRate * 2, true);
  view.setUint16(32, 2, true);
  view.setUint16(34, 16, true);
  writeString(36, 'data');
  view.setUint32(40, pcmData.length, true);

  const pcmView = new Uint8Array(buffer, 44);
  pcmView.set(pcmData);

  return new Blob([buffer], { type: 'audio/wav' });
};

// --- COMPONENT: STARLINK GAME ---
const StarLink = ({ onStarEarned }) => {
  const GRID_SIZE = 7;
  const [grid, setGrid] = useState([]);
  const [selected, setSelected] = useState(null);
  const [score, setScore] = useState(0);

  useEffect(() => {
    const initialGrid = Array.from({ length: GRID_SIZE * GRID_SIZE }, () => 
      STAR_TYPES[Math.floor(Math.random() * STAR_TYPES.length)]
    );
    setGrid(initialGrid);
  }, []);

  const playSound = (key) => {
    try {
      const audio = new Audio(SOUNDS[key]);
      audio.volume = 0.4;
      audio.play().catch(() => {});
    } catch (e) {}
  };

  const handleTileClick = (index) => {
    if (selected === null) {
      setSelected(index);
      playSound('click');
    } else {
      const isAdjacent = 
        Math.abs(selected - index) === 1 || 
        Math.abs(selected - index) === GRID_SIZE;
      
      if (isAdjacent) {
        const newGrid = [...grid];
        const temp = newGrid[selected];
        newGrid[selected] = newGrid[index];
        newGrid[index] = temp;
        setGrid(newGrid);
        setScore(s => s + 150);
        playSound('match');
        if (score + 150 >= 1000) onStarEarned();
      }
      setSelected(null);
    }
  };

  return (
    <div className="p-4 bg-black/40 rounded-2xl border border-white/10 backdrop-blur-xl shadow-inner">
      <div className="flex justify-between mb-4 font-mono text-[10px] text-gold-400">
        <span>STARLINK PROTOCOL ACTIVE</span>
        <span>INSIGHT: {score}</span>
      </div>
      <div className="grid gap-1.5" style={{ gridTemplateColumns: `repeat(${GRID_SIZE}, 1fr)` }}>
        {grid.map((star, i) => (
          <motion.div
            key={i}
            whileHover={{ scale: 1.1, backgroundColor: 'rgba(255,255,255,0.1)' }}
            whileTap={{ scale: 0.9 }}
            onClick={() => handleTileClick(i)}
            className={`w-8 h-8 md:w-10 md:h-10 flex items-center justify-center rounded-lg cursor-pointer transition-colors ${
              selected === i ? 'bg-white/20 ring-1 ring-white shadow-[0_0_10px_white]' : 'bg-white/5'
            }`}
            style={{ color: star.color }}
          >
            {star.icon}
          </motion.div>
        ))}
      </div>
    </div>
  );
};

