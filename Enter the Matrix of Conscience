                          className="flex-grow bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-xs focus:outline-none focus:border-indigo-500 transition-all"
                        />
                        <button 
                          onClick={() => interrogate("Dr. Reed")}
                          disabled={isInterrogating}
                          className="px-4 py-2 bg-indigo-600 text-white rounded-xl text-[10px] font-bold hover:bg-indigo-500 disabled:opacity-50"
                        >REED</button>
                        <button 
                          onClick={() => interrogate("Lord Blackwood")}
                          disabled={isInterrogating}
                          className="px-4 py-2 bg-purple-600 text-white rounded-xl text-[10px] font-bold hover:bg-purple-500 disabled:opacity-50"
                        >WOOD</button>
                      </div>
                    </div>
                  )}

                  {chapter.hasGame && <div className="mb-8"><StarLink onStarEarned={handleStarEarned} /></div>}

                  {chapter.isVision && (
                    <motion.div initial={{ scale: 0.95 }} animate={{ scale: 1 }} className="p-12 bg-gold-500/10 border-2 border-gold-500/30 rounded-[2rem] flex flex-col items-center text-center gap-4 relative overflow-hidden shadow-[0_0_50px_rgba(255,215,0,0.1)]">
                      <Sparkles className="text-gold-400 relative z-10" size={48} />
                      <h3 className="text-2xl font-bold text-gold-400 relative z-10">SHEILA: GUARDIAN OF GRACE</h3>
                      <p className="text-gold-200/60 italic text-sm relative z-10">"The digital threads and the starlight are one, Nicholai."</p>
                    </motion.div>
                  )}
                </div>

                {/* NAV */}
                <div className="flex justify-between items-center mt-12 pt-8 border-t border-white/5 relative z-10">
                  <div className="flex gap-2">
                    {CHAPTERS.map((_, i) => (
                      <div key={i} className={`w-1.5 h-1.5 rounded-full transition-all duration-500 ${i === currentChapter ? 'w-8 bg-gold-500' : 'bg-white/10'}`} />
                    ))}
                  </div>

                  {chapter.isFinal ? (
                    <button onClick={() => window.location.href='matrix.html'} className="flex items-center gap-4 px-10 py-5 bg-gold-500 text-black font-black rounded-2xl hover:bg-white transition-all shadow-xl">
                      <Sparkles size={20} /> ENTER THE MATRIX <ArrowRight />
                    </button>
                  ) : (
                    <button onClick={handleNext} className="flex items-center gap-3 px-8 py-4 bg-white/5 hover:bg-white/10 rounded-2xl text-xs font-bold border border-white/10 transition-all">
                      NEXT CHAPTER <ChevronRight size={18} />
                    </button>
                  )}
                </div>
              </motion.div>
            </AnimatePresence>

            {/* ✨ BOTTOM MORAL LATTICE */}
            <div className="mt-8 p-4 rounded-3xl bg-white/[0.03] border border-white/10 backdrop-blur-3xl shadow-2xl flex flex-wrap items-center justify-between gap-4">
              <div className="flex items-center gap-2 text-[10px] font-bold text-gold-500 uppercase tracking-widest min-w-[140px]">
                <Brain size={12} /> Moral Lattice
              </div>
              <div className="flex-grow flex flex-wrap gap-6 justify-end">
                {Object.entries(pillars).map(([name, value]) => (
                  <div key={name} className="flex items-center gap-3 min-w-[120px]">
                    <div className="flex flex-col">
                      <span className="text-[8px] font-mono text-white/40 uppercase mb-1">{name}</span>
                      <span className="text-[10px] font-bold text-gold-400">{value}%</span>
                    </div>
                    <div className="h-1 w-16 bg-white/5 rounded-full overflow-hidden">
                      <motion.div animate={{ width: `${value}%` }} className={`h-full bg-gradient-to-r ${name === 'Wisdom' ? 'from-purple-500 to-indigo-400' : name === 'Justice' ? 'from-red-500 to-orange-400' : name === 'Empathy' ? 'from-pink-500 to-rose-400' : 'from-green-500 to-emerald-400'}`} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>
        </div>

        <footer className="mt-24 pt-8 border-t border-white/5 opacity-30 flex justify-between">
          <p className="text-[10px] font-mono tracking-widest uppercase">Amazing Grace HL • Sector 7</p>
          <div className="flex gap-8">
            <button className="text-[10px] font-bold hover:text-gold-500">SYSTEM LOG</button>
            <button className="text-[10px] font-bold hover:text-gold-500">SPECTRAL MAP</button>
          </div>
        </footer>
      </main>
      
      {/* SEVEN STAR ALIGNMENT */}
      <div className="fixed left-8 top-1/2 -translate-y-1/2 hidden 2xl:flex flex-col gap-6">
        {STAR_TYPES.map((star, i) => (
          <motion.div key={i} animate={{ opacity: stars > i ? 1 : 0.1, scale: stars > i ? 1.2 : 1 }} className="text-2xl drop-shadow-lg">{star.icon}</motion.div>
        ))}
      </div>
    </div>
  );
}